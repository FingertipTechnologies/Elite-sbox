<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Month_Year_Required</fullName>
    <active>true</active>
    <errorConditionFormula>AND(Is_Monthly_Forecast__c, OR(ISBLANK(TEXT(Forecast_Month__c)), ISBLANK(TEXT(Forecast_Year__c))))</errorConditionFormula>
    <errorMessage>Forecast Month and Forecast Year are both required.</errorMessage>
</ValidationRule>
