<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Distributor_Required</fullName>
    <active>true</active>
    <errorConditionFormula>AND(Is_Monthly_Forecast__c, ISBLANK(Distributor__c))</errorConditionFormula>
    <errorDisplayField>Distributor__c</errorDisplayField>
    <errorMessage>Distributor is required.</errorMessage>
</ValidationRule>
