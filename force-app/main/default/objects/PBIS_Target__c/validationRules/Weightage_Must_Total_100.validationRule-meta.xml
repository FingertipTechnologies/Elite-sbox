<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Weightage_Must_Total_100</fullName>
    <active>true</active>
    <description>BR-02: when any component weightage is entered, the ten component weightages must total 100%.</description>
    <errorConditionFormula>AND(
  Total_Weightage__c &lt;&gt; 0,
  Total_Weightage__c &lt;&gt; 100
)</errorConditionFormula>
    <errorDisplayField>Total_Weightage__c</errorDisplayField>
    <errorMessage>Component weightages must total 100%.</errorMessage>
</ValidationRule>
